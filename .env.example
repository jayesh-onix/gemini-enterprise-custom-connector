# ─────────────────────────────────────────────────────────────────────────────
# JSONPlaceholder → Gemini Enterprise Connector
# Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values
# NEVER commit .env to source control
# ─────────────────────────────────────────────────────────────────────────────

# ── GCP Project ───────────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-project-id
GCP_LOCATION=global

# ── GCS Staging Bucket ────────────────────────────────────────────────────────
# The connector will create this bucket if it does not exist
GCS_BUCKET=your-staging-bucket
GCS_BLOB=documents/jsonplaceholder_posts.jsonl

# ── Discovery Engine Data Store ───────────────────────────────────────────────
# The connector will create this data store with ACL_ENABLED=TRUE if it does not exist
DATA_STORE_ID=your-data-store-id
COLLECTION_ID=default_collection
BRANCH_ID=0

# ── Source API ────────────────────────────────────────────────────────────────
# JSONPlaceholder — no auth required (perfect for testing)
SOURCE_BASE_URL=https://jsonplaceholder.typicode.com

# ── Secret Manager (Production Security) ──────────────────────────────────────
# Name of the secret containing your source API key (e.g., {"api_key": "..."})
SECRET_API_CREDENTIALS=your-api-secret-name

# Name of the secret containing your ACL mapping (e.g., {"readers": [{"user": "..."}]})
SECRET_ACL_MAPPING=your-ge-acl-mapping

# ── Sync Mode ─────────────────────────────────────────────────────────────────
# "full"        : replaces entire dataset (handles deletions) — use for testing
# "incremental" : adds/updates only, does not delete — use for production sync
SYNC_MODE=incremental
